PORT=5000
MONGO_URI=your_mongodb_atlas_connection_string
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Render sets this automatically in production; leave unset locally so
# error responses include detail for debugging.
NODE_ENV=development

# Optional - real destination cover photos on trip cards. Free signup at
# pexels.com/api. If omitted, trip cards fall back to a gradient+monogram
# design instead of a photo - the app works fine either way.
PEXELS_API_KEY=your_pexels_api_key